{
  "packages": {
    "python": {"version": "3.14"},
    "python314Packages.pip": {"version": "25.3"},

    "bpftrace": {"version": "0.24.2"},
    "sysstat": {"version": "12.7.7"},
    "fio": {"version": "3.41"},

    "clang_18": {"version": "18.1.8"},
    "bpftools": {"version": "6.18.7"},
    "libbpf": {"version": "1.6.3"},
    "elfutils": {"version": "0.194", "outputs": ["bin", "man", "dev", "out"]},
    "zlib": {"version": "1.3.1"}
  },
  "env_from": "./.env",
  "env": {
    "ROOT_DIR": "$PWD",
    "RESULTS_DIR": "$PWD/results",

    "VENV_DIR": "./.venv",
    "PIP_REQUIRE_VIRTUALENV": "true"
  },
  "shell": {
    "init_hook": [
      "if [ ! -d \"$VENV_DIR\" ]; then python -m venv \"$VENV_DIR\"; fi",
      ". $VENV_DIR/bin/activate",

      "mkdir -p $RESULTS_DIR",

      "clear",
      "echo -e \"\\nDevbox started!\""
    ],
    "scripts": {
      "update_pip": ["pip install -r ./requirements.txt"],
      "install_ig": ["make -C ./subs/inspektor-gadget ig"]
    }
  }
}
