    if (@write_start[tid])
    {
        @sc_completed["write"] = count();

        if ($ret >= 0)
        {
            @sc_latencies["write"] = hist($now - @write_start[tid]);
            @sc_sizes["write"] = hist($ret);
            @sc_total_bytes["write"] = sum($ret);
