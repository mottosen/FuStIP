config =
{
    unstable_tseries=enable;
}

BEGIN
{
    print("bpftrace - FS Layer\n");

    @comm_filter = $1;
}

// ── read() ──

tracepoint:syscalls:sys_enter_read
/ strcontains(@comm_filter, comm) /
{
    @sc_entered["read"] = count();
    @read_start[tid] = nsecs;
}

tracepoint:syscalls:sys_exit_read
/ strcontains(@comm_filter, comm) /
{
    $now = nsecs;
    $ret = (int64)args.ret;

    if (@read_start[tid])
    {
        @sc_completed["read"] = count();

        if ($ret >= 0)
        {
            @sc_latencies["read"] = hist($now - @read_start[tid]);
            @sc_sizes["read"] = hist($ret);
            @sc_total_bytes["read"] = sum($ret);
        }

        delete(@read_start[tid]);
    }
    else
    {
        @sc_untracked["read"] = count();
    }
}

// ── write() ──

tracepoint:syscalls:sys_enter_write
/ strcontains(@comm_filter, comm) /
{
    @sc_entered["write"] = count();
    @write_start[tid] = nsecs;
}

tracepoint:syscalls:sys_exit_write
/ strcontains(@comm_filter, comm) /
{
