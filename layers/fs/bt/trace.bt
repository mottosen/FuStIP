// ── Additional syscall counts (enter-only) ──

tracepoint:syscalls:sys_enter_openat
/ strcontains(@comm_filter, comm) /
{
    @sc_count["openat"] = count();
}

tracepoint:syscalls:sys_enter_close
/ strcontains(@comm_filter, comm) /
{
    @sc_count["close"] = count();
}

tracepoint:syscalls:sys_enter_lseek
/ strcontains(@comm_filter, comm) /
{
    @sc_count["lseek"] = count();
}

tracepoint:syscalls:sys_enter_newfstatat
/ strcontains(@comm_filter, comm) /
{
    @sc_count["newfstatat"] = count();
}

tracepoint:syscalls:sys_enter_newfstat
/ strcontains(@comm_filter, comm) /
{
    @sc_count["newfstat"] = count();
}

tracepoint:syscalls:sys_enter_unlinkat
/ strcontains(@comm_filter, comm) /
{
    @sc_count["unlinkat"] = count();
}

tracepoint:syscalls:sys_enter_mkdirat
/ strcontains(@comm_filter, comm) /
{
    @sc_count["mkdirat"] = count();
}

tracepoint:syscalls:sys_enter_mmap
/ strcontains(@comm_filter, comm) /
{
    @sc_count["mmap"] = count();
}

tracepoint:syscalls:sys_enter_munmap
/ strcontains(@comm_filter, comm) /
{
    @sc_count["munmap"] = count();
}

// ── Inflight time-series ──

interval:s:1
{
    @sc_inflight["read"] = tseries(@sc_entered["read"] - @sc_completed["read"], 1s, 120);
    @sc_inflight["write"] = tseries(@sc_entered["write"] - @sc_completed["write"], 1s, 120);
    @sc_inflight["pread64"] = tseries(@sc_entered["pread64"] - @sc_completed["pread64"], 1s, 120);
    @sc_inflight["pwrite64"] = tseries(@sc_entered["pwrite64"] - @sc_completed["pwrite64"], 1s, 120);
}

// ── Output ──

END
{
    print(@sc_entered);
    print(@sc_completed);
    print(@sc_untracked);
    print(@sc_count);
    print("");

    print(@sc_total_bytes);
    print("");

    print(@sc_sizes);
    print(@sc_latencies);
    print(@sc_inflight);


    clear(@sc_latencies);
    clear(@sc_sizes);
    clear(@sc_total_bytes);

    clear(@read_start);
    clear(@write_start);
    clear(@pread_start);
    clear(@pwrite_start);

    clear(@sc_entered);
    clear(@sc_completed);
    clear(@sc_untracked);
    clear(@sc_count);

    clear(@sc_inflight);

    delete(@comm_filter);
}
